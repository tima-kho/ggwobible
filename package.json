{
  "name": "bible-presenter",
  "version": "1.0.0",
  "description": "Лёгкое веб-приложение для церкви: вывод стихов из Библии на проектор. RST, кыргызский KYB, KJV, 66 книг, поиск, второй экран.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build:data": "node scripts/build-data.js",
    "build:songs": "node scripts/build-songs.js",
    "export:kyb": "node scripts/build-data.js --kyb-only",
    "build:frontend": "node scripts/build-frontend.js",
    "dev:frontend": "node --watch scripts/build-frontend.js",
    "start": "node src/index.js",
    "dev": "node --watch src/index.js"
  },
  "dependencies": {
    "@fastify/static": "^7.0.4",
    "fastify": "^4.28.1"
  },
  "devDependencies": {
    "esbuild": "^0.25.12"
  }
}
